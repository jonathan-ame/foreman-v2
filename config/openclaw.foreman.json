{
  env: {
    vars: {
      DEEPSEEK_API_KEY: "${DEEPSEEK_API_KEY}",
      GROQ_API_KEY: "${GROQ_API_KEY}",
      DASHSCOPE_API_KEY: "${DASHSCOPE_API_KEY}",
    },
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "deepseek/deepseek-chat",
        fallbacks: [
          "deepseek/deepseek-reasoner",
          "together/deepseek-ai/DeepSeek-V3",
          "groq/qwen/qwen3-32b",
          "qwen/qwen3-32b",
          "qwen/qwen3-coder-plus",
          "qwen/qwen3-coder-flash",
          "groq/openai/gpt-oss-20b",
        ],
      },
      models: {
        "deepseek/deepseek-chat": { alias: "DeepSeek V3.2 Chat" },
        "deepseek/deepseek-reasoner": { alias: "DeepSeek V3.2 Reasoner" },
        "together/deepseek-ai/DeepSeek-V3": { alias: "Together DeepSeek V3 (prospective)" },
        "groq/qwen/qwen3-32b": { alias: "Groq Qwen3-32B" },
        "groq/openai/gpt-oss-20b": { alias: "Groq GPT-OSS-20B" },
        "qwen/qwen3-coder-plus": { alias: "DashScope Qwen3 Coder Plus" },
        "qwen/qwen3-coder-flash": { alias: "DashScope Qwen3 Coder Flash" },
        "qwen/qwen3-32b": { alias: "DashScope Qwen3-32B" },
        "qwen/text-embedding-v4": { alias: "DashScope Text Embedding V4" },
      },
      compaction: {
        mode: "safeguard",
        model: "deepseek/deepseek-chat",
      },
    },
    list: [
      {
        id: "ceo",
        default: true,
        name: "Foreman CEO",
        workspace: "~/.openclaw/workspace-ceo",
        model: {
          primary: "deepseek/deepseek-chat",
          fallbacks: [
            "deepseek/deepseek-reasoner",
            "together/deepseek-ai/DeepSeek-V3",
            "groq/qwen/qwen3-32b",
            "qwen/qwen3-32b",
            "qwen/qwen3-coder-plus",
            "qwen/qwen3-coder-flash",
            "groq/openai/gpt-oss-20b",
          ],
        },
        params: {
          temperature: 0.2,
          maxTokens: 6144,
        },
        subagents: {
          allowAgents: ["*"],
          requireAgentId: true,
        },
        tools: {
          allow: [
            "read",
            "write",
            "edit",
            "exec",
            "process",
            "sessions_spawn",
            "sessions_list",
            "sessions_history",
          ],
          deny: ["browser", "canvas", "nodes", "cron"],
        },
      },
    ],
  },

  models: {
    mode: "merge",
    providers: {
      // Legacy shell-path compatibility shim:
      // scripts/paperclip-openclaw-executor.sh preflight requires models.providers.executor
      // with baseUrl/apiKey/models[].id, even though runtime model routing is now provider-native.
      executor: {
        baseUrl: "https://api.deepseek.com",
        apiKey: "${DEEPSEEK_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "deepseek-chat",
            name: "Legacy executor preflight model",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
        ],
      },
      qwen: {
        // Force DashScope Global OpenAI-compatible endpoint for non-China traffic.
        baseUrl: "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
        apiKey: "${DASHSCOPE_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "qwen3-coder-plus",
            name: "Qwen3 Coder Plus",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 262144,
            maxTokens: 8192,
          },
          {
            id: "qwen3-coder-flash",
            name: "Qwen3 Coder Flash",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 262144,
            maxTokens: 8192,
          },
          {
            id: "qwen3-32b",
            name: "Qwen3 32B",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
          {
            id: "text-embedding-v4",
            name: "Text Embedding V4",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192,
          },
        ],
      },
    },
  },

  gateway: {
    mode: "local",
    bind: "loopback",
    http: {
      endpoints: {
        chatCompletions: { enabled: true },
      },
    },
  },

  channels: {},
}
