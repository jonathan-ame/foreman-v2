{
  // Provider-per-role template. configure.sh writes this file to ~/.openclaw/openclaw.json.
  agents: {
    defaults: {
      model: {
        primary: "executor/PLACEHOLDER_EXECUTOR_MODEL",
      },
      compaction: {
        mode: "safeguard",
        model: "planner/PLACEHOLDER_PLANNER_MODEL",
      },
      workspace: "~/.openclaw/workspace",
    },
    list: [
      {
        id: "main",
        tools: {
          allow: ["read", "edit", "write", "exec", "process", "web_search", "web_fetch"],
        },
        skills: ["coding-agent", "github", "gh-issues", "summarize"],
      },
      {
        id: "ceo-planner",
        model: {
          primary: "planner/PLACEHOLDER_PLANNER_MODEL",
        },
        // Keep probe/system prompt footprint small to preserve token headroom.
        workspace: "~/.openclaw/workspace/foreman-v2-ceo-min",
      },
      {
        id: "ceo-executor",
        model: {
          primary: "executor/PLACEHOLDER_EXECUTOR_MODEL",
        },
        tools: {
          allow: [],
        },
        skills: [],
        workspace: "~/.openclaw/workspace/foreman-v2-ceo-min",
      },
      {
        id: "ceo-reviewer",
        model: {
          primary: "reviewer/PLACEHOLDER_REVIEWER_MODEL",
        },
        tools: {
          allow: [],
        },
        skills: [],
        workspace: "~/.openclaw/workspace/foreman-v2-ceo-min",
      },
    ],
  },

  models: {
    mode: "merge",
    providers: {
      executor: {
        baseUrl: "https://api.deepinfra.com/v1/openai",
        apiKey: "${DEEPINFRA_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "PLACEHOLDER_EXECUTOR_MODEL",
            name: "Foreman v2 Executor",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 16384,
            maxTokens: 64,
          },
        ],
      },
      planner: {
        baseUrl: "https://api.deepinfra.com/v1/openai",
        apiKey: "${DEEPINFRA_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "PLACEHOLDER_PLANNER_MODEL",
            name: "Foreman v2 Planner",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 16384,
            maxTokens: 1024,
          },
        ],
      },
      reviewer: {
        baseUrl: "https://api.deepinfra.com/v1/openai",
        apiKey: "${DEEPINFRA_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "PLACEHOLDER_REVIEWER_MODEL",
            name: "Foreman v2 Reviewer",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 16384,
            maxTokens: 64,
          },
        ],
      },
      embedding: {
        baseUrl: "https://api.deepinfra.com/v1/openai",
        apiKey: "${DEEPINFRA_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "PLACEHOLDER_EMBEDDING_MODEL",
            name: "Foreman v2 Embedding",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 4096,
          },
        ],
      },
    },
  },

  // Foreman CEO token budget contract (hybrid model, consumed by executor pipeline):
  // {
  //   "clampPolicy": "fail-loud",
  //   "providers": {
  //     "planner": {
  //       "hard_ceiling": 16384,
  //       "safety_margin_tokens": 256,
  //       "default_max_output_tokens": 1024,
  //       "purposes": {
  //         "plan_generation": { "max_output_tokens": 1024 },
  //         "synthesis": { "max_output_tokens": 6144 },
  //         "probe": { "max_output_tokens": 256 }
  //       }
  //     },
  //     "executor": {
  //       "hard_ceiling": 16384,
  //       "safety_margin_tokens": 256,
  //       "default_max_output_tokens": 64,
  //       "purposes": {
  //         "step_execution": { "max_output_tokens": 4096 },
  //         "probe": { "max_output_tokens": 64 }
  //       }
  //     },
  //     "reviewer": {
  //       "hard_ceiling": 16384,
  //       "safety_margin_tokens": 256,
  //       "default_max_output_tokens": 64,
  //       "purposes": {
  //         "code_analysis": { "max_output_tokens": 4096 },
  //         "critique": { "max_output_tokens": 1024 },
  //         "probe": { "max_output_tokens": 64 }
  //       }
  //     }
  //   }
  // }

  gateway: {
    mode: "local",
    bind: "loopback",
    http: {
      endpoints: {
        chatCompletions: { enabled: true },
      },
    },
  },

  channels: {},
}
