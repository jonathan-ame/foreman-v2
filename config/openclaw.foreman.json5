{
  env: {
    vars: {
      TOGETHER_API_KEY: "${TOGETHER_API_KEY}",
      DASHSCOPE_US_KEY: "${DASHSCOPE_US_KEY}",
      DASHSCOPE_SG_KEY: "${DASHSCOPE_SG_KEY}",
    },
  },

  agents: {
    defaults: {
      workspace: "~/.openclaw/workspace",
      model: {
        primary: "together/deepseek-ai/DeepSeek-V3.1",
        fallbacks: [],
      },
      models: {
        "together/deepseek-ai/DeepSeek-V3.1": {
          alias: "DeepSeek V3.1 (via Together)",
        },
        "qwen/qwen3-coder-plus": { alias: "Qwen3-Coder 480B (US Virginia)" },
        "qwen/qwen3-32b": { alias: "Qwen3 32B (US Virginia)" },
        "qwen/qwen-flash": { alias: "Qwen Flash (US Virginia)" },
        "qwen_embedding/text-embedding-v4": {
          alias: "Qwen3 Embedding v4 (Singapore)",
        },
      },
      compaction: {
        mode: "safeguard",
        model: "together/deepseek-ai/DeepSeek-V3.1",
      },
    },
    list: [
      {
        id: "ceo",
        default: true,
        name: "Foreman CEO",
        workspace: "~/.openclaw/workspace-ceo",
        model: {
          primary: "together/deepseek-ai/DeepSeek-V3.1",
          fallbacks: [],
        },
        params: {
          temperature: 0.2,
          maxTokens: 6144,
        },
        subagents: {
          allowAgents: ["*"],
          requireAgentId: true,
        },
        tools: {
          allow: [
            "read",
            "write",
            "edit",
            "exec",
            "process",
            "sessions_spawn",
            "sessions_list",
            "sessions_history",
          ],
          deny: ["browser", "canvas", "nodes", "cron"],
        },
      },
    ],
  },

  models: {
    mode: "merge",
    providers: {
      executor: {
        baseUrl: "https://api.together.xyz/v1",
        apiKey: "${TOGETHER_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "deepseek-ai/DeepSeek-V3.1",
            name: "Legacy executor preflight model (Together DeepSeek V3.1)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
        ],
      },
      together: {
        baseUrl: "https://api.together.xyz/v1",
        apiKey: "${TOGETHER_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "deepseek-ai/DeepSeek-V3.1",
            name: "DeepSeek V3.1 (via Together)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
        ],
      },
      qwen: {
        // DashScope US (Virginia) OpenAI-compatible endpoint for this account region.
        baseUrl: "https://dashscope-us.aliyuncs.com/compatible-mode/v1",
        apiKey: "${DASHSCOPE_US_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "qwen3-coder-plus",
            name: "Qwen3-Coder 480B (US Virginia)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 262144,
            maxTokens: 8192,
          },
          {
            id: "qwen3-32b",
            name: "Qwen3 32B (US Virginia)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
          {
            id: "qwen-flash",
            name: "Qwen Flash (US Virginia)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 4096,
          },
        ],
      },
      qwen_embedding: {
        // text-embedding-v4 is served via DashScope Singapore.
        baseUrl: "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
        apiKey: "${DASHSCOPE_SG_KEY}",
        // OpenClaw schema does not currently expose an openai-embeddings adapter enum.
        // Keep openai-completions transport and target embedding model id explicitly.
        api: "openai-completions",
        models: [
          {
            id: "text-embedding-v4",
            name: "Qwen3 Embedding v4 (Singapore)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192,
          },
        ],
      },
    },
  },
}
