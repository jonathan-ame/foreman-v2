{
  env: {
    vars: {
      OPENROUTER_API_KEY: "${OPENROUTER_API_KEY}",
      DASHSCOPE_SG_KEY: "${DASHSCOPE_SG_KEY}",
      PAPERCLIP_API_URL: "${PAPERCLIP_API_URL}",
      PAPERCLIP_COMPANY_ID: "${PAPERCLIP_COMPANY_ID}",
      PAPERCLIP_AGENT_ID: "${PAPERCLIP_AGENT_ID}",
    },
  },
  agents: {
    defaults: {
      model: {
        primary: "openrouter/deepseek/deepseek-v3.2",
        fallbacks: [],
      },
      models: {
        // Chat models via OpenRouter
        "openrouter/deepseek/deepseek-chat-v3.1": { alias: "DeepSeek V3.1 (OpenRouter)" },
        "openrouter/deepseek/deepseek-v3.2": { alias: "DeepSeek V3.2 (OpenRouter)" },
        "openrouter/z-ai/glm-5.1": { alias: "GLM 5.1 (OpenRouter)" },
        "openrouter/qwen/qwen3-coder": { alias: "Qwen3 Coder (OpenRouter)" },
        "openrouter/qwen/qwen-2.5-72b-instruct": { alias: "Qwen 2.5 72B (OpenRouter)" },
        "openrouter/meta-llama/llama-3.3-70b-instruct": { alias: "Llama 3.3 70B (OpenRouter)" },
        // Embeddings via DashScope (unchanged)
        "qwen_embedding/text-embedding-v4": { alias: "Qwen3 Embedding v4 (Singapore)" },
      },
      compaction: {
        mode: "safeguard",
        model: "openrouter/deepseek/deepseek-chat-v3.1",
      },
    },
    list: [
      {
        id: "ceo",
        default: true,
        name: "Foreman CEO",
        workspace: "~/.openclaw/workspace-ceo",
        model: {
          primary: "openrouter/deepseek/deepseek-v3.2",
          fallbacks: [],
        },
        params: {
          temperature: 0.2,
          maxTokens: 6144,
        },
        subagents: {
          allowAgents: ["*"],
          requireAgentId: true,
        },
        tools: {
          allow: [
            "read",
            "write",
            "edit",
            "exec",
            "process",
            "sessions_spawn",
            "sessions_list",
            "sessions_history",
            "hire_agent",
          ],
          deny: ["browser", "canvas", "nodes", "cron"],
        },
      },
    ],
  },
  models: {
    mode: "merge",
    providers: {
      openrouter: {
        baseUrl: "https://openrouter.ai/api/v1",
        apiKey: "${OPENROUTER_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "deepseek/deepseek-chat-v3.1",
            name: "DeepSeek V3.1 (OpenRouter)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0.15, output: 0.75, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
          {
            id: "deepseek/deepseek-v3.2",
            name: "DeepSeek V3.2 (OpenRouter)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0.26, output: 0.38, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 163840,
            maxTokens: 8192,
          },
          {
            id: "z-ai/glm-5.1",
            name: "GLM 5.1 (OpenRouter)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0.95, output: 3.15, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 202752,
            maxTokens: 131072,
          },
          {
            id: "qwen/qwen3-coder",
            name: "Qwen3 Coder (OpenRouter)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0.30, output: 1.20, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 262144,
            maxTokens: 8192,
          },
          {
            id: "qwen/qwen-2.5-72b-instruct",
            name: "Qwen 2.5 72B (OpenRouter)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0.13, output: 0.40, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
          {
            id: "meta-llama/llama-3.3-70b-instruct",
            name: "Llama 3.3 70B (OpenRouter)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0.13, output: 0.39, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 131072,
            maxTokens: 8192,
          },
        ],
      },
      executor: {
        baseUrl: "https://openrouter.ai/api/v1",
        apiKey: "${OPENROUTER_API_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "deepseek/deepseek-v3.2",
            name: "DeepSeek V3.2 (OpenRouter)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0.26, output: 0.38, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 163840,
            maxTokens: 163840,
          },
          {
            id: "z-ai/glm-5.1",
            name: "GLM 5.1 (OpenRouter)",
            reasoning: true,
            input: ["text"],
            cost: { input: 0.95, output: 3.15, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 202752,
            maxTokens: 131072,
          },
        ],
      },
      qwen_embedding: {
        baseUrl: "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
        apiKey: "${DASHSCOPE_SG_KEY}",
        api: "openai-completions",
        models: [
          {
            id: "text-embedding-v4",
            name: "Qwen3 Embedding v4 (Singapore)",
            reasoning: false,
            input: ["text"],
            cost: { input: 0.05, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 32768,
            maxTokens: 8192,
          },
        ],
      },
    },
  },
  plugins: {
    load: {
      paths: ["~/.openclaw/plugins/foreman-hire-agent", "~/.openclaw/plugins/foreman-token-meter"],
    },
    entries: {
      openrouter: { enabled: true },
      "foreman-hire-agent": {
        enabled: true,
        config: {
          apiBaseUrl: "http://127.0.0.1:8080",
          requestTimeoutMs: 30000,
        },
      },
      "foreman-token-meter": {
        enabled: true,
        config: {
          paperclipApiBase: "${PAPERCLIP_API_URL}",
          paperclipCompanyId: "${PAPERCLIP_COMPANY_ID}",
          paperclipAgentId: "${PAPERCLIP_AGENT_ID}",
          foremanApiBase: "http://localhost:8080",
        },
      },
    },
  },
}
