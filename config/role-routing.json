{
  "version": 1,
  "owner": "foreman-v2",
  "source_of_truth": "OpenClaw provider routing contract",
  "roles": {
    "executor": {
      "provider": "executor",
      "route_role": "executor",
      "transport": "openclaw_agent",
      "model_id": "PLACEHOLDER_EXECUTOR_MODEL",
      "base_url_source": "config/openclaw.foreman.json",
      "health_probe_path": "/chat/completions",
      "notes": "Default interactive and chat path."
    },
    "planner": {
      "provider": "planner",
      "route_role": "planner",
      "transport": "openai_chat",
      "model_id": "PLACEHOLDER_PLANNER_MODEL",
      "base_url_source": "config/openclaw.foreman.json",
      "health_probe_path": "/chat/completions",
      "notes": "Reasoning and planning path."
    },
    "embedding": {
      "provider": "embedding",
      "route_role": "embedding",
      "transport": "openai_embeddings",
      "model_id": "PLACEHOLDER_EMBEDDING_MODEL",
      "base_url_source": "config/openclaw.foreman.json",
      "health_probe_path": "/embeddings",
      "notes": "Embedding and vector path."
    },
    "reviewer": {
      "provider": "reviewer",
      "route_role": "reviewer",
      "transport": "openai_chat",
      "model_id": "PLACEHOLDER_REVIEWER_MODEL",
      "base_url_source": "config/openclaw.foreman.json",
      "health_probe_path": "/chat/completions",
      "notes": "Code review and codebase QA path."
    }
  },
  "dispatch_contract": {
    "default_chat_role": "executor",
    "planning_role": "planner",
    "embedding_role": "embedding",
    "review_role": "reviewer"
  }
}
