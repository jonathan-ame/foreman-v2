{
  "name": "@foreman/backend",
  "version": "0.1.0",
  "description": "Foreman v2 backend — orchestration, billing, and agent provisioning",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc && pnpm --dir web build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "vitest run",
    "test:e2e": "pnpm exec playwright install chromium && pnpm --dir web build && FOREMAN_RUN_E2E=1 vitest run test/e2e/full-customer-journey.test.ts --testTimeout=600000",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli/index.ts",
    "import-subscribers": "tsx src/scripts/import-subscribers.ts",
    "run-migration": "tsx src/scripts/run-migration.ts",
    "migrate:up": "tsx src/scripts/run-migration-neon.ts up",
    "migrate:status": "tsx src/scripts/run-migration-neon.ts status",
    "migrate:apply": "tsx src/scripts/run-migration-neon.ts apply"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@neondatabase/serverless": "^1.1.0",
    "@sentry/node": "^10.49.0",
    "@supabase/supabase-js": "^2.103.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "hono": "^4.12.14",
    "json5": "^2.2.3",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "stripe": "^22.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
