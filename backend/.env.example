# Runtime mode: development | production | test
NODE_ENV=development
# HTTP server port
PORT=8080
# Logger level: debug | info | warn | error
LOG_LEVEL=info
# Supabase project URL
SUPABASE_URL=https://example.supabase.co
# Supabase service role key (secret)
SUPABASE_SERVICE_KEY=replace-with-supabase-service-key
# Paperclip API base URL
PAPERCLIP_API_BASE=http://localhost:3125
# Paperclip API key (secret)
PAPERCLIP_API_KEY=replace-with-paperclip-api-key
# OpenClaw binary name or absolute path
OPENCLAW_BIN=openclaw
# OpenClaw gateway websocket URL
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789/
# OpenClaw runtime config path
OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OpenClaw Foreman include config path
OPENCLAW_INCLUDE_PATH=~/.openclaw/foreman.json5
# OpenRouter API key (secret)
OPENROUTER_API_KEY=replace-with-openrouter-api-key
# DashScope Singapore key (secret)
DASHSCOPE_SG_KEY=replace-with-dashscope-sg-key
# Stripe mode selector: test (default for development) | live (production)
STRIPE_MODE=test
# Live mode Stripe secret key (secret)
STRIPE_SECRET_KEY=sk_live_...
# Live mode Stripe webhook signing secret (secret)
STRIPE_WEBHOOK_SECRET=whsec_...
# Live mode Stripe price ID for Foreman Starter
STRIPE_PRICE_TIER_1=price_1TIz16LIeTmtbHlGztPskQJJ
# Live mode Stripe price ID for Foreman Growth
STRIPE_PRICE_TIER_2=price_1TMbalLIeTmtbHlGXoY5ceFx
# Live mode Stripe price ID for Foreman Scale
STRIPE_PRICE_TIER_3=price_1TMbakLIeTmtbHlGQ9QpVgcv
# Live mode Stripe price ID for Foreman BYOK Platform
STRIPE_PRICE_BYOK_PLATFORM=price_1TMbakLIeTmtbHlGu8Oz8tUc
# Test mode Stripe secret key (secret)
STRIPE_SECRET_KEY_TEST=sk_test_...
# Test mode Stripe webhook signing secret (secret)
STRIPE_WEBHOOK_SECRET_TEST=whsec_test_...
# Test mode Stripe price ID for Foreman Starter
STRIPE_PRICE_TIER_1_TEST=price_1TMeL7LIeTmtbHlG6R6reoJb
# Test mode Stripe price ID for Foreman Growth
STRIPE_PRICE_TIER_2_TEST=price_1TMeL8LIeTmtbHlGCj8H13rp
# Test mode Stripe price ID for Foreman Scale
STRIPE_PRICE_TIER_3_TEST=price_1TMeL9LIeTmtbHlGbgdqeDYK
# Test mode Stripe price ID for Foreman BYOK Platform
STRIPE_PRICE_BYOK_PLATFORM_TEST=price_1TMeLALIeTmtbHlGnoXQqZks
# Foreman backend log directory
FOREMAN_LOG_DIR=~/.foreman/logs
# GA4 Measurement ID (optional, enables web analytics when set)
GA4_MEASUREMENT_ID=
# Resend API key for transactional email delivery (secret)
RESEND_API_KEY=
# Sender email address for transactional emails
EMAIL_FROM=
# Email address for CEO review reports
CEO_REVIEW_EMAIL=
# Composio API key for external integrations (secret)
COMPOSIO_API_KEY=
# Composio API base URL
COMPOSIO_API_BASE=https://backend.composio.dev
# Composio webhook signing secret (secret)
COMPOSIO_WEBHOOK_SECRET=
# Composio connected account ID for Outlook email sending
COMPOSIO_CONNECTED_ACCOUNT_ID_OUTLOOK=
# Composio user ID for API calls
COMPOSIO_USER_ID=paperclip_company_b8d234ec-515c-4331-9a5a-bb2f0c239ef5
# Enable rate limiting (true/false, default: true)
RATE_LIMIT_ENABLED=true
# Max requests per window for standard endpoints
RATE_LIMIT_STANDARD_MAX=100
# Max requests per window for strict endpoints
RATE_LIMIT_STRICT_MAX=20
# Max requests per window for auth endpoints
RATE_LIMIT_AUTH_MAX=10
# Window duration in ms for standard/strict/lenient buckets
RATE_LIMIT_WINDOW_MS=60000
# Window duration in ms for auth endpoints (default: 15 min)
RATE_LIMIT_AUTH_WINDOW_MS=900000
# Comma-separated list of allowed CORS origins (e.g. "https://app.example.com,https://staging.example.com")
# Wildcard subdomains supported: "*.example.com" matches any subdomain of example.com
# Leave empty to disable CORS (no Access-Control-Allow-Origin headers will be set)
CORS_ALLOWED_ORIGINS=
# Max age in seconds for CORS preflight cache (default: 86400)
CORS_MAX_AGE=86400
# Neon PostgreSQL connection string for migrations and direct SQL access
# Use the pooler endpoint (-pooler.) for production: postgres://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb
NEON_DATABASE_URL=
# Neon Auth base URL (defaults to production endpoint)
NEON_AUTH_URL=https://ep-calm-voice-amfgpq8c.neonauth.c-5.us-east-1.aws.neon.tech/neondb/auth
# Neon Auth JWKS URI for JWT verification (defaults to production endpoint)
NEON_AUTH_JWKS_URL=https://ep-calm-voice-amfgpq8c.neonauth.c-5.us-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
# BYOK API key encryption key (base64-encoded, 32+ chars) — required for BYOK feature
BYOK_ENCRYPTION_KEY=
# Foreman base URL for external callbacks and links
FOREMAN_BASE_URL=https://foreman.company
# Sentry DSN for error monitoring (optional)
SENTRY_DSN=
