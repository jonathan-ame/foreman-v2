# ═══════════════════════════════════════════════════════════════════════════════
# Foreman Phase 1 — Credential Reference
# See docs/credential-management.md for full documentation
# ═══════════════════════════════════════════════════════════════════════════════
#
# Classifications:
#   [Public]     — Safe to share (payment links, mode selectors)
#   [Internal]   — Don't expose publicly but low risk (project URLs, account IDs)
#   [Restricted] — Never expose (API keys, secrets, tokens)
#
# Rotation policy shows days; 0 = no rotation required
# ═══════════════════════════════════════════════════════════════════════════════

# ─── AI / Model Providers ─────────────────────────────────────────────────────

# [Restricted] Rotation: 90d — OpenRouter API key for LLM provider routing
OPENROUTER_API_KEY=
# [Restricted] Rotation: 90d — DashScope Singapore (text-embedding-v4)
DASHSCOPE_SG_KEY=
# [Restricted] Rotation: 90d — DashScope US Virginia (chat workers)
DASHSCOPE_US_KEY=
# [Restricted] Rotation: 90d — Together AI (CEO planner, DeepSeek V3.1)
TOGETHER_API_KEY=
# [Restricted] Rotation: 90d — DeepInfra (OpenClaw template validation)
DEEPINFRA_API_KEY=

# ─── Railway ──────────────────────────────────────────────────────────────────

# [Restricted] Rotation: 90d — Railway deployment API token
RAILWAY_API_KEY=

# ─── Stripe ───────────────────────────────────────────────────────────────────

# [Public] Stripe mode: 'live' or 'test'
STRIPE_MODE=test
# [Restricted] Rotation: 90d — Live secret key
STRIPE_SECRET_KEY=
# [Restricted] Rotation: 180d — Live webhook signing secret
STRIPE_WEBHOOK_SECRET=
# [Internal] Live price IDs (semi-public, used in checkout)
STRIPE_PRICE_TIER_1=
STRIPE_PRICE_TIER_2=
STRIPE_PRICE_TIER_3=
STRIPE_PRICE_BYOK_PLATFORM=
# [Public] Payment link URLs
STRIPE_LINK_STARTER_ANNUAL=
STRIPE_LINK_GROWTH=
STRIPE_LINK_PRO_ANNUAL=
STRIPE_LINK_BUSINESS_ANNUAL=
STRIPE_LINK_COMPLETE=
# [Restricted] Rotation: 90d — Test secret key
STRIPE_SECRET_KEY_TEST=
# [Restricted] Rotation: 180d — Test webhook signing secret
STRIPE_WEBHOOK_SECRET_TEST=
# [Internal] Test price IDs
STRIPE_PRICE_TIER_1_TEST=
STRIPE_PRICE_TIER_2_TEST=
STRIPE_PRICE_TIER_3_TEST=
STRIPE_PRICE_BYOK_PLATFORM_TEST=

# ─── Supabase ─────────────────────────────────────────────────────────────────

# [Internal] Supabase project URL
SUPABASE_URL=
# [Restricted] Rotation: 90d — Service role key (bypasses RLS, server-side only!)
SUPABASE_SERVICE_KEY=
# [Internal] Rotation: 180d — Anon/public key (client-side, respects RLS)
SUPABASE_ANON_KEY=

# ─── Cloudflare ───────────────────────────────────────────────────────────────

# [Restricted] Rotation: 90d — API token for DNS/zone management
CLOUDFLARE_API_TOKEN=
# [Internal] Account identifier
CLOUDFLARE_ACCOUNT_ID=
# [Internal] DNS zone ID for foreman.company
CLOUDFLARE_ZONE_ID=
# [Internal] Load balancer IDs
CLOUDFLARE_LOAD_BALANCER_ID=
CLOUDFLARE_LOAD_BALANCER_POOL_ID=

# ─── Resend (DEFERRED — blocked by FORA-42) ───────────────────────────────────

# [Restricted] Rotation: 90d — Resend API key for transactional email
# ⏳ Deferred: CEO must obtain from resend.com
RESEND_API_KEY=
# [Public] Sender email address
EMAIL_FROM=
# [Public] CEO review notification email
CEO_REVIEW_EMAIL=

# ─── Sentry (DEFERRED — blocked by FORA-42) ───────────────────────────────────

# [Internal] Sentry DSN for error monitoring
# ⏳ Deferred: CEO must create project at sentry.io
SENTRY_DSN=

# ─── Composio ────────────────────────────────────────────────────────────────

# [Restricted] Rotation: 90d — Composio API key for external toolkit integration
# Obtain from platform.composio.dev/settings
COMPOSIO_API_KEY=ak_PULpf7NT75uqQGyGl6lk
# [Internal] Composio API base URL (defaults to https://backend.composio.dev)
COMPOSIO_API_BASE=https://backend.composio.dev
# [Restricted] Rotation: 180d — Webhook signing secret for Composio trigger events
COMPOSIO_WEBHOOK_SECRET=

# ─── OpenClaw / Paperclip ────────────────────────────────────────────────────

# [Internal] OpenClaw gateway WebSocket URL
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789/
# [Restricted] Rotation: 90d — Gateway auth token (if token-protected)
OPENCLAW_GATEWAY_TOKEN=

# OpenClaw substrate (see config/openclaw.foreman.json):
# - Together AI: CEO planner (DeepSeek V3.1 pass-through)
TOGETHER_API_KEY=
# - DashScope US Virginia (chat workers: qwen3-coder-plus, qwen3-32b, qwen-flash)
DASHSCOPE_US_KEY=
# - DashScope Singapore (text-embedding-v4 only; not available on US Virginia endpoint)
DASHSCOPE_SG_KEY=

# Optional holdovers (not wired into active Foreman providers; safe to omit until restored)
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# Paperclip P2.1 local baseline:
# - npx paperclipai onboard --yes
# - default API/UI endpoint is http://127.0.0.1:3100
PAPERCLIP_BASE_URL=http://127.0.0.1:3100
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_HOME=
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_TELEMETRY_DISABLED=1

# OpenClaw agent runtime called by Paperclip adapters:
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# Optional if your gateway is token-protected.
OPENCLAW_GATEWAY_TOKEN=
