# RunPod API key (same env var name used by foreman/).
RUNPOD_API_KEY=

# Three-pod roster (Secure Cloud only, always-on pods):
# - embedding: Qwen/Qwen3-Embedding-8B
# - executor:  Qwen/Qwen3-14B-AWQ
# - planner:   Qwen/Qwen3-30B-A3B-Instruct-2507
#
# Pod IDs and proxy URLs are discovered and written by scripts/provision.sh
# to state/pods.json, then consumed by scripts/configure.sh.
# See docs/INFERENCE-ENDPOINTS.md for details.

# Paperclip P2.1 local baseline:
# - npx paperclipai onboard --yes
# - default API/UI endpoint is http://127.0.0.1:3100
PAPERCLIP_BASE_URL=http://127.0.0.1:3100
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_HOME=
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_TELEMETRY_DISABLED=1

# OpenClaw agent runtime called by Paperclip adapters:
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# Optional if your gateway is token-protected.
OPENCLAW_GATEWAY_TOKEN=
