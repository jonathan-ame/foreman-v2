# RunPod API key (same env var name used by foreman/).
RUNPOD_API_KEY=
# Optional preflight spend guard (hours of balance required before provisioning).
# Default is 24 in scripts/provision.sh. For retry loops use 4.
RUNPOD_MIN_BALANCE_HOURS=24
# Stale network volume cleanup policy (used by scripts/cleanup-stale-volumes.sh):
# - Prefix match for candidate stale volumes
# - Optional comma-separated keep-list to protect specific names
# - Safety cap for max deletions per apply run
RUNPOD_VOLUME_CLEANUP_PREFIX=foreman-models-
RUNPOD_VOLUME_KEEP_NAMES=
RUNPOD_VOLUME_CLEANUP_MAX_DELETE=50

# Four-pod roster (Secure Cloud only, always-on pods):
# - embedding: Qwen/Qwen3-Embedding-8B
# - executor:  Qwen/Qwen2.5-32B-Instruct
# - planner:   deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
# - reviewer:  Qwen/Qwen2.5-Coder-32B-Instruct
#
# Pod IDs and proxy URLs are discovered and written by scripts/provision.sh
# to state/pods.json, then consumed by scripts/configure.sh.
# See docs/INFERENCE-ENDPOINTS.md for details.

# Paperclip P2.1 local baseline:
# - npx paperclipai onboard --yes
# - default API/UI endpoint is http://127.0.0.1:3100
PAPERCLIP_BASE_URL=http://127.0.0.1:3100
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_HOME=
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_TELEMETRY_DISABLED=1

# OpenClaw agent runtime called by Paperclip adapters:
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# Optional if your gateway is token-protected.
OPENCLAW_GATEWAY_TOKEN=
