# DeepInfra API key used by OpenClaw provider configuration.
# Phase 1 wires this to concrete model IDs in config/openclaw.foreman.json.
DEEPINFRA_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_SG_API_KEY=

# Paperclip P2.1 local baseline:
# - npx paperclipai onboard --yes
# - default API/UI endpoint is http://127.0.0.1:3100
PAPERCLIP_BASE_URL=http://127.0.0.1:3100
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_HOME=
PAPERCLIP_DEPLOYMENT_MODE=local_trusted
PAPERCLIP_TELEMETRY_DISABLED=1

# OpenClaw agent runtime called by Paperclip adapters:
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# Optional if your gateway is token-protected.
OPENCLAW_GATEWAY_TOKEN=
